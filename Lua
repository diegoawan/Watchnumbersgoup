local Tab1 = Window:CreateTab("Reset", 4483362458)

local AutoRebirth = false
local RebirthDelay = 5

Tab1:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(Value)
        AutoRebirth = Value
        while AutoRebirth do
            local args = { "Rebirth" }
            game:GetService("ReplicatedStorage")
                :WaitForChild("Objects")
                :WaitForChild("Remotes")
                :WaitForChild("Prestige")
                :WaitForChild("DoPrestige")
                :FireServer(unpack(args))
            task.wait(RebirthDelay)
        end
    end
})

Tab1:CreateSlider({
    Name = "Rebirth Speed",
    Range = {0.1, 600},
    Increment = 0.1,
    CurrentValue = 10,
    Callback = function(Value)
        RebirthDelay = Value
    end
})

