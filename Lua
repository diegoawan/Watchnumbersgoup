local Tab2 = Window:CreateTab("Upgrades", 4483362458)

-- Normal upgrades (NumMulti_XXX)
local AutoUpgrade = false

Tab2:CreateToggle({
    Name = "Auto Upgrades (Smart MAX Detect)",
    CurrentValue = false,
    Callback = function(Value)
        AutoUpgrade = Value
        while AutoUpgrade do
            for i = 1, 500 do
                local id = "NumMulti_" .. string.format("%03d", i)
                local upgradeModel = workspace:FindFirstChild("UpgradeModels")
                if upgradeModel and upgradeModel:FindFirstChild(id) then
                    local obj = upgradeModel[id]
                    local label = obj.Display.SurfaceGui.Frame.Frame:FindFirstChild("CostLabel")
                    if label and label:IsA("TextLabel") then
                        if not string.find(label.Text, "%[MAX%]") then
                            local args = { id }
                            game:GetService("ReplicatedStorage")
                                :WaitForChild("Objects")
                                :WaitForChild("Remotes")
                                :WaitForChild("Upgrades")
                                :WaitForChild("BuyUpgrade")
                                :FireServer(unpack(args))
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end
})

