-- ================= TAB 3 (TELEPORT) =================
local Tab3 = Window:CreateTab("Teleport", 4483362458)

-- Helper function to teleport player
local function teleportTo(cframe)
    local player = game.Players.LocalPlayer
    local character = player.Character
    if character then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = cframe
        end
    end
end

-- Define locations from given data
local locations = {
    Transcension = CFrame.new(-29, 74.9500122, -779, 1, 0, 0, 0, 1, 0, 0, 0, 1),
    Ascension    = CFrame.new(-29, 74.9500122, -407, 1, 0, 0, 0, 1, 0, 0, 0, 1),
    Rebirth      = CFrame.new(-29, 74.9500122, -107, 1, 0, 0, 0, 1, 0, 0, 0, 1),
    Gems         = CFrame.new(42.9615326, 74.7692261, -647, -1, 0, 0, 0, 1, 0, 0, 0, -1),
    Challenges   = CFrame.new(23.4615326, 74.7692261, -528.5, -1, 0, 0, 0, 1, 0, 0, 0, -1),
    Runes        = CFrame.new(48, 75.2384644, -255, -1, 0, 0, 0, 1, 0, 0, 0, -1)
}

-- Create a button for each location
for name, cframe in pairs(locations) do
    Tab3:CreateButton({
        Name = name,
        Callback = function()
            teleportTo(cframe)
            Rayfield:Notify("Teleported to " .. name, "Info")
        end
    })
end

Tab3:CreateLabel("Click any button to teleport instantly")
